# =============================================
# HBCUStockMarketChallenge2026 – Bot Config
# Copy this file to .env and fill in your values
# =============================================

# OpenAI API Key — get from https://platform.openai.com/
OPENAI_API_KEY=your_openai_api_key_here

# Stock-Trak credentials
STOCKTRAK_USER=your_stocktrak_username
STOCKTRAK_PASS=your_stocktrak_password

# ── Competition Settings ──────────────────────────────────────────────────────
# Set to your actual competition end date (YYYY-MM-DD). The bot uses this to
# auto-tune aggression: more trades and lower confidence threshold near the end.
COMPETITION_END_DATE=2026-05-16

# Assumed starting capital for position sizing. StockTrak default is $100,000.
POSITION_BASE_CAPITAL=100000

# OpenAI model — gpt-4o is fast and capable. Use gpt-4o-mini to reduce cost.
OPENAI_MODEL=gpt-4o

# ── Trade Gating (override defaults here) ────────────────────────────────────
# Lower = more trades. 72 is competition-mode. Raise to 80 to be more selective.
CONFIDENCE_THRESHOLD=72

# RANK_GUARD_MODE: allow = fully automated. prompt = ask before trading in top 10.
# skip = never trade when in top 10 (safe but passive).
RANK_GUARD_MODE=allow

# ── Data interval ─────────────────────────────────────────────────────────────
# 1h = hourly candles (responsive, best for 30-min cycle bot)
# 1d = daily candles  (smoother, classic indicators)
DATA_INTERVAL=1h
DATA_PERIOD=60d
